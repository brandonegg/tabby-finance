{
  "name": "tabby-finance",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "maestro:auth:foundation": "maestro test .maestro/auth-foundation.yaml",
    "maestro:auth:signup": "maestro test .maestro/auth-signup.yaml",
    "maestro:auth:login": "maestro test .maestro/auth-login.yaml",
    "maestro:auth:all": "maestro test .maestro",
    "maestro:user": "node scripts/maestro-test-user.mjs",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format .",
    "format:fix": "biome format --fix .",
    "prepare": "husky",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@better-auth/expo": "^1.5.4",
    "better-auth": "^1.5.4",
    "better-sqlite3": "^12.6.2",
    "drizzle-orm": "^0.45.1",
    "expo": "~55.0.5",
    "expo-constants": "~55.0.7",
    "expo-linking": "~55.0.7",
    "expo-network": "~55.0.8",
    "expo-router": "~55.0.4",
    "expo-secure-store": "~55.0.8",
    "expo-status-bar": "~55.0.4",
    "expo-web-browser": "~55.0.9",
    "nativewind": "^4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-reanimated": "^4.2.2",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "~19.2.2",
    "drizzle-kit": "^0.31.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "tailwindcss": "^3",
    "typescript": "~5.9.2"
  },
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json}": "biome check --fix --no-errors-on-unmatched"
  }
}
